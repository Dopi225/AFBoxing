# Configuration .htaccess pour le backend
# Permet de servir les fichiers uploads et le routing API

<IfModule mod_rewrite.c>
    RewriteEngine On

    # IMPORTANT (prod/Apache/FastCGI) :
    # Préserve l'en-tête Authorization pour que PHP puisse lire le Bearer token.
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
    
    # Servir les fichiers uploads directement
    # RewriteCond %{REQUEST_URI} ^/uploads/
    # RewriteCond %{DOCUMENT_ROOT}/backend/public%{REQUEST_URI} -f
    # RewriteRule ^uploads/(.*)$ backend/public/uploads/$1 [L]
    
    # Si le fichier demandé existe, le servir
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]
    
    # Pour toutes les autres requêtes, router vers index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# Sécurité : Empêcher l'accès direct aux fichiers de configuration
<FilesMatch "^(config\.php|\.env)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Headers de sécurité
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "DENY"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

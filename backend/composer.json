{
  "name": "afboxing/backend",
  "description": "API REST sécurisée pour AF Boxing Club",
  "type": "project",
  "require": {
    "php": "^8.2",
    "vlucas/phpdotenv": "^5.6",
    "firebase/php-jwt": "^6.10",
    "phpmailer/phpmailer": "^6.9",
    "respect/validation": "^2.4",
    "monolog/monolog": "^3.7",
    "symfony/var-dumper": "^7.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.3",
    "mockery/mockery": "^1.6"
  },
  "autoload": {
    "psr-4": {
      "AFBoxing\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "AFBoxing\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml"
  }
}
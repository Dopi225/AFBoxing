APP_ENV=development

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=afboxing
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Secret fort (≥ 32 caractères) pour signer les JWT
JWT_SECRET=change_me_to_a_long_random_secret

# Origines autorisées pour le navigateur (séparées par des virgules)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Mettre à 1 pour refuser toute origine hors liste même en développement
# CORS_STRICT=0

# Derrière un reverse proxy qui envoie X-Forwarded-For / X-Real-IP
# TRUSTED_PROXY=0

<IfModule mod_headers.c>
  # Sécurité/Perf basiques
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# NOTE:
# On évite un "SPA fallback" générique avant la config principale ci-dessous,
# sinon certaines requêtes /api/* peuvent être réécrites vers index.html (HTML)
# au lieu d'atteindre le backend (JSON).

<IfModule mod_deflate.c>
  # GZIP (texte)
  AddOutputFilterByType DEFLATE text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_brotli.c>
  # Brotli (si activé sur Apache)
  AddOutputFilterByType BROTLI_COMPRESS text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  # Cache long pour fichiers versionnés (hash) générés par Vite
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType video/mp4 "access plus 1 year"
  # HTML court (pour que les updates arrivent vite)
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  # Cache-Control cohérent
  <FilesMatch "\.(css|js|mjs|map|png|jpe?g|gif|svg|webp|mp4)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

# ============================================
# Configuration .htaccess pour MattingMatch
# Production - Optimisé pour Hostinger
# ============================================

# Activer le moteur de réécriture
<IfModule mod_rewrite.c>
    RewriteEngine On
    # RewriteBase :
    # Ne pas forcer "/" ici : en sous-dossier (ex: /AF/AFBoxing/), ça casse les reload de routes.
    # Apache calcule généralement la base automatiquement en contexte .htaccess.

    # IMPORTANT (prod/Apache/FastCGI) :
    # Préserve l'en-tête Authorization pour que PHP puisse lire le Bearer token.
    # Sans ça, l'API peut répondre "Authorization header missing" même si le navigateur envoie le header.
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
    
    # Rediriger HTTP vers HTTPS (décommentez si vous avez SSL)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
    
    # ============================================
    # PRIORITÉ 1 : Servir les fichiers uploads
    # ============================================
    # Servir les fichiers uploads depuis backend/public/uploads
    # Supporte aussi un déploiement en sous-dossier: /AF/AFBoxing/uploads/...
    RewriteCond %{REQUEST_URI} (^|/)uploads/
    RewriteRule ^(.*?/)?uploads/(.*)$ backend/public/uploads/$2 [L]
    
    # ============================================
    # PRIORITÉ 2 : Ne pas traiter /backend directement
    # ============================================
    RewriteCond %{REQUEST_URI} (^|/)backend/
    RewriteRule ^ - [L]
    
    # ============================================
    # PRIORITÉ 3a : Exception pour les fichiers de debug PHP
    # ============================================
    # Servir directement les fichiers debug_*.php depuis backend/public/
    RewriteRule ^(.*?/)?api/(debug_[^/]+\.php)$ backend/public/$2 [L]
    
    # ============================================
    # PRIORITÉ 3b : API - Rediriger /api vers /backend/public/index.php
    # ============================================
    # Supporte aussi un déploiement en sous-dossier: /AF/AFBoxing/api/...
    RewriteCond %{REQUEST_URI} (^|/)api(/|$)
    RewriteRule ^.*$ backend/public/index.php [L]

    # Forcer la racine à servir le build (dist/) ou (index.html) selon la structure déployée
    RewriteCond %{REQUEST_URI} ^/?$
    RewriteCond %{DOCUMENT_ROOT}/dist/index.html -f
    RewriteRule ^$ dist/index.html [L]

    RewriteCond %{REQUEST_URI} ^/?$
    RewriteCond %{DOCUMENT_ROOT}/index.html -f
    RewriteRule ^$ index.html [L]
    
    # ============================================
    # PRIORITÉ 4 : Servir les fichiers statiques
    # ============================================
    # Servir les fichiers statiques buildés depuis dist/ (supporte aussi un sous-dossier)
    RewriteCond %{REQUEST_URI} (^|/)(assets/[^?]+|vite\.svg|[^?]+\.(css|js|mjs|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|webp))$
    RewriteCond %{DOCUMENT_ROOT}/dist/%2 -f
    RewriteRule ^.*$ dist/%2 [L]
    
    # Si le fichier existe directement (production), le servir
    RewriteCond %{REQUEST_URI} ^/(assets/|vite\.svg|.*\.(css|js|mjs|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|webp))$
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]
    
    # ============================================
    # PRIORITÉ 5 : Si le fichier existe directement, le servir
    # ============================================
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]
    
    # ============================================
    # PRIORITÉ 6 : Si c'est un dossier qui existe, ne pas réécrire
    # ============================================
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
    
    # ============================================
    # PRIORITÉ 7 : SPA React - Rediriger vers index.html
    # ============================================
    # Pour toutes les autres requêtes (SPA), servir dist/index.html si présent,
    # sinon fallback sur index.html (quand le contenu de dist a été copié à la racine).
    RewriteCond %{REQUEST_URI} !^(.*/)?api/
    RewriteCond %{REQUEST_URI} !^(.*/)?backend/
    RewriteCond %{REQUEST_URI} !^(.*/)?uploads/
    RewriteCond %{DOCUMENT_ROOT}/dist/index.html -f
    RewriteRule ^(.*)$ dist/index.html [L]

    RewriteCond %{REQUEST_URI} !^(.*/)?api/
    RewriteCond %{REQUEST_URI} !^(.*/)?backend/
    RewriteCond %{REQUEST_URI} !^(.*/)?uploads/
    RewriteCond %{DOCUMENT_ROOT}/index.html -f
    RewriteRule ^(.*)$ index.html [L]
</IfModule>

# ============================================
# Désactiver la liste des répertoires
# ============================================
Options -Indexes

# ============================================
# Protéger les fichiers sensibles
# ============================================
<FilesMatch "\.(env|log|ini|conf|htaccess|htpasswd|bak|backup|sql|db|md)$">
    Require all denied
</FilesMatch>

# Protéger les fichiers de configuration
<FilesMatch "^(config|database|auth|security)\.php$">
    Require all denied
</FilesMatch>

